#!/usr/bin/env python3
"""bs-webctl pre-commit gate (Agent-SE-SPEC §4, content checks only).

Message/ADR-reference checks live in commit-msg — pre-commit runs before the
commit message exists, so it cannot validate the message.

Ponytail: scope kept to the ONE content rule only pre-commit can do (§4-3:
new .feature needs a PRD). Template-field and step-naming checks are the
linter's job (step 5), not duplicated here.
"""
import sys, subprocess
from pathlib import Path


def fail(msg, hint=""):
    print(f"[pre-commit] ✗ {msg}", file=sys.stderr)
    if hint:
        print(f"  see: {hint}", file=sys.stderr)
    sys.exit(1)


def staged():
    out = subprocess.check_output(
        ["git", "diff", "--cached", "--name-only", "--diff-filter=ACMR"],
        text=True, errors="replace",
    )
    return [p for p in out.splitlines() if p]


def main():
    files = staged()
    if not files:
        return
    # §4 rule 3: a new .feature must have a PRD (or explicit exemption in prose)
    new_features = [p for p in files if p.endswith(".feature")]
    if new_features:
        prd_dir = Path("prd")
        has_prd = prd_dir.exists() and any(prd_dir.iterdir())
        if not has_prd:
            fail("new .feature staged but prd/ has no PRD",
                 "Agent-SE-SPEC §4-3 — add a PRD, or declare exemption in the feature")
    sys.exit(0)


if __name__ == "__main__":
    main()
